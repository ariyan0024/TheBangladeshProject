rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {

      // Anyone can read (public feed + directory)
      allow read: if true;

      // Anyone can create (public submissions)
      // Enforce required fields and default status
      allow create: if request.resource.data.keys().hasAll(['name','comment','status','timestamp'])
                    && request.resource.data.status == 'pending'
                    && request.resource.data.name is string
                    && request.resource.data.comment is string;

      // Only authenticated admins can update or delete
      allow update, delete: if request.auth != null;
    }
  }
}
